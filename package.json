{
	"name": "hy-canvas-minimap",
	"version": "0.1.0",
	"description": "Minimap for Obsidian Canvas",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "node deploy.mjs",
		"build:deploy": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node deploy.mjs",
		"release": "node release.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"canvas",
		"minimap"
	],
	"author": "lugglory",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "^2.4.0",
		"typescript": "^4.7.4"
	}
}
